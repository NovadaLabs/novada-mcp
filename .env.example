# Required: Scraper API key — get from dashboard.novada.com → Scraper API
NOVADA_API_KEY=your-scraper-api-key

# Optional: Web Unblocker key — for JS-heavy sites (Cloudflare, SPAs)
# Get from dashboard.novada.com → Web Unblocker
NOVADA_WEB_UNBLOCKER_KEY=your-web-unblocker-key

# Optional: Browser API WSS endpoint — for full CDP browser sessions
# Get from dashboard.novada.com → Browser API → Playwright/Puppeteer voucher
NOVADA_BROWSER_WS=wss://username:password@upg-scbr.novada.com

# Optional: Residential proxy credentials
# Get from dashboard.novada.com → Residential Proxies → Endpoint Generator
NOVADA_PROXY_USER=your-proxy-username
NOVADA_PROXY_PASS=your-proxy-password
NOVADA_PROXY_ENDPOINT=host:port
